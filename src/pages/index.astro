---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Captura el Momento | Comparte las fotos de tu evento con un QR';
const pageDescription =
	'Crea un album colaborativo para bodas, fiestas y cumpleaños. Comparte un QR, recibe todas las fotos de tus invitados y pruebalo gratis hasta julio.';

const steps = [
	{
		title: 'Crea tu evento en minutos',
		description:
			'Configura el nombre del evento, personaliza la portada y genera un espacio privado para reunir todas las fotos.',
	},
	{
		title: 'Comparte un QR con tus invitados',
		description:
			'Imprime el codigo en mesas, invitaciones o pantallas para que cualquiera pueda entrar sin descargar nada complicado.',
	},
	{
		title: 'Recibe recuerdos al instante',
		description:
			'Cada invitado sube sus fotos desde el movil y el album se llena en tiempo real con todos los momentos que normalmente se pierden.',
	},
];

const benefits = [
	{
		title: 'Mas fotos, menos esfuerzo',
		description:
			'Consigue fotos desde todos los angulos sin perseguir a nadie por WhatsApp despues del evento.',
	},
	{
		title: 'Ideal para bodas y celebraciones',
		description:
			'Funciona especialmente bien en bodas, cumpleaños, comuniones, baby showers y fiestas privadas.',
	},
	{
		title: 'Acceso rapido por QR',
		description:
			'Los invitados entran con una experiencia simple y movil, sin registros eternos ni instrucciones confusas.',
	},
	{
		title: 'Album compartido y ordenado',
		description:
			'Todo queda centralizado en un mismo lugar para descargar, revisar y conservar los mejores recuerdos.',
	},
	{
		title: 'Listo para eventos reales',
		description:
			'Pensado para anfitriones y organizadores que quieren una solucion visual, elegante y facil de explicar.',
	},
	{
		title: 'Gratis hasta julio',
		description:
			'Aprovecha la etapa de lanzamiento para usar Captura el Momento sin coste hasta el 31 de julio de 2026.',
	},
];

const faqItems = [
	{
		question: 'Que es Captura el Momento?',
		answer:
			'Es una app para recopilar fotos de eventos mediante un codigo QR. Los invitados escanean, suben sus imagenes y todas quedan reunidas en un mismo album digital.',
	},
	{
		question: 'Mis invitados tienen que instalar una app?',
		answer:
			'No. La experiencia esta pensada para que puedan acceder desde el movil de forma rapida y sencilla a traves del QR del evento.',
	},
	{
		question: 'Para que tipo de eventos sirve?',
		answer:
			'Esta enfocada en bodas, fiestas, cumpleaños y celebraciones donde quieres reunir recuerdos de todos los asistentes sin complicaciones.',
	},
	{
		question: 'Cuanto cuesta?',
		answer:
			'Ahora mismo es gratuita hasta el 31 de julio de 2026. Es una oportunidad ideal para probarla en tus proximos eventos y validar el formato.',
	},
	{
		question: 'Que ventaja tiene frente a pedir fotos por chat?',
		answer:
			'Evita mensajes dispersos, perdida de archivos y conversaciones interminables. Todas las fotos se centralizan en un unico espacio preparado para el evento.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const softwareSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Captura el Momento',
	applicationCategory: 'PhotoApplication',
	operatingSystem: 'Web',
	description: pageDescription,
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'EUR',
		availability: 'https://schema.org/InStock',
		description: 'Gratis hasta el 31 de julio de 2026',
	},
	audience: {
		'@type': 'Audience',
		audienceType: 'Personas que organizan bodas, fiestas y cumpleaños',
	},
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="/"
	structuredData={[faqSchema, softwareSchema]}
>
	<main>
		<section class="hero section" id="hero-top">
			<div class="container hero-grid">
				<div class="hero-copy">
					<span class="eyebrow">Gratis hasta julio de 2026</span>
					<h1>Centraliza las fotos de tu evento con un QR simple de compartir.</h1>
					<p>
						Captura el Momento convierte bodas, fiestas y cumpleaños en albumes colaborativos.
						Crea el evento, comparte un QR o enlace y recibe fotos de tus invitados en un panel
						claro, bonito y pensado para usarlo de verdad.
					</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href="https://app.capturaelmomento.com">Empezar gratis</a>
						<a class="btn btn-secondary" href="#como-funciona">Ver como funciona</a>
					</div>
					<ul class="hero-proof" aria-label="Ventajas principales">
						<li>Sin procesos complicados para tus invitados</li>
						<li>Perfecto para bodas, cumpleaños y fiestas</li>
						<li>Album colaborativo centralizado</li>
					</ul>
				</div>
				<div class="hero-panel card">
					<div class="hero-panel-top">
						<p class="panel-label">Evento activo</p>
						<strong>Panel del evento</strong>
					</div>
					<div class="phone-frame">
						<div class="qr-badge">QR + enlace listos para compartir</div>
						<div class="upload-card">
							<span>Fotos subidas</span>
							<strong>11</strong>
						</div>
						<div class="photo-stack" aria-hidden="true">
							<div></div>
							<div></div>
							<div></div>
							<div></div>
						</div>
					</div>
					<div class="stats-grid">
						<div>
							<span>Evento activo</span>
							<strong>1</strong>
						</div>
						<div>
							<span>Listo para invitados</span>
							<strong>Si</strong>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="section" id="como-funciona">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Como funciona</span>
					<h2>Una experiencia simple para ti y natural para tus invitados.</h2>
					<p>
						No necesitas grupos caoticos ni pedir fotos despues. La propuesta esta pensada para que
						cualquier invitado entre, suba imagenes y las deje ordenadas en el mismo sitio.
					</p>
				</div>

				<div class="grid steps-grid">
					{
						steps.map((step, index) => (
							<article class="card step-card">
								<div class="step-index">0{index + 1}</div>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section benefits-section" id="beneficios">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Beneficios</span>
					<h2>Hecha para eventos donde cada foto cuenta.</h2>
					<p>
						Desde la perspectiva de los anfitriones hasta la comodidad de los invitados, todo esta
						pensado para aumentar la participacion y conservar mejores recuerdos.
					</p>
				</div>

				<div class="grid benefits-grid">
					{
						benefits.map((benefit) => (
							<article class="card benefit-card">
								<h3>{benefit.title}</h3>
								<p>{benefit.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section pricing-section" id="precios">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Precios</span>
					<h2>Lanzamiento abierto para que pruebes la experiencia en eventos reales.</h2>
					<p>
						La mejor forma de descubrir su valor es usarla en una celebracion de verdad. Por eso
						Captura el Momento sera gratuita hasta julio.
					</p>
				</div>

				<div class="pricing-card card">
					<div>
						<p class="pricing-kicker">Plan lanzamiento</p>
						<h3>Gratis hasta el 31 de julio de 2026</h3>
						<p>
							Crea tu evento, comparte el QR y empieza a reunir fotos sin coste durante la fase de
							lanzamiento.
						</p>
					</div>
					<div class="price-tag">
						<span>0 EUR</span>
						<small>Acceso promocional</small>
					</div>
					<ul class="pricing-list">
						<li>Creacion de eventos y album colaborativo</li>
						<li>Acceso mediante QR para invitados</li>
						<li>Ideal para bodas, fiestas y cumpleaños</li>
						<li>Sin permanencia durante el periodo gratuito</li>
					</ul>
					<a class="btn btn-primary" href="https://app.capturaelmomento.com">Quiero probarla en mi evento</a>
				</div>
			</div>
		</section>

		<section class="section faq-section" id="faq">
			<div class="container faq-layout">
				<div class="section-heading">
					<span class="eyebrow">FAQ</span>
					<h2>Resuelve las dudas antes de lanzar el QR en tu evento.</h2>
					<p>
						Esta seccion esta estructurada para que tus visitantes y los buscadores entiendan rapido
						que hace la app, para quien es y por que merece probarla.
					</p>
				</div>
				<div class="faq-list">
					{
						faqItems.map((item) => (
							<details class="card faq-item">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="section final-cta" id="cta-final">
			<div class="container">
				<div class="card cta-card">
					<div>
						<span class="eyebrow">Preparado para convertir invitados en fotografos</span>
						<h2>Haz que cada mesa, brindis y baile termine tambien en tu album.</h2>
						<p>
							Prueba Captura el Momento gratis hasta julio de 2026 y crea una experiencia facil de
							compartir, bonita de presentar y muy simple de usar.
						</p>
					</div>
					<div class="cta-actions">
						<a class="btn btn-primary" href="https://app.capturaelmomento.com">Entrar en la app</a>
						<a class="btn btn-secondary" href="#hero-top">Volver arriba</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container footer-content">
			<div>
				<a class="footer-brand" href="/">Captura el Momento</a>
				<p>Comparte un QR y reune todas las fotos de tu evento en un mismo lugar.</p>
			</div>
			<nav aria-label="Navegacion secundaria" class="footer-nav">
				<a href="#como-funciona">Como funciona</a>
				<a href="#beneficios">Beneficios</a>
				<a href="#precios">Precios</a>
				<a href="#faq">FAQ</a>
			</nav>
		</div>
	</footer>
</Layout>

<style>
	.hero {
		padding-top: 2rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: 2rem;
		align-items: center;
	}

	.hero-copy h1 {
		margin: 1rem 0 1rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(3rem, 6vw, 5.4rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
		max-width: 11ch;
	}

	.hero-copy p {
		max-width: 60ch;
		margin: 0;
		font-size: 1.12rem;
		line-height: 1.8;
		color: var(--muted);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin: 2rem 0 1.5rem;
	}

	.hero-proof {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.hero-proof li {
		padding: 0.7rem 0.95rem;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid var(--line);
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 700;
	}

	.hero-panel {
		padding: 1.5rem;
		position: relative;
		overflow: hidden;
	}

	.hero-panel::before {
		content: '';
		position: absolute;
		inset: auto -10% -18% auto;
		width: 240px;
		height: 240px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(217, 231, 255, 0.95), transparent 68%);
	}

	.hero-panel-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.panel-label,
	.pricing-kicker {
		margin: 0 0 0.3rem;
		font-size: 0.92rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--secondary);
	}

	.phone-frame {
		position: relative;
		min-height: 420px;
		padding: 1.35rem;
		border-radius: 28px;
		background:
			linear-gradient(180deg, rgba(47, 103, 246, 0.1), rgba(255, 255, 255, 0.76)),
			linear-gradient(135deg, #fff 0%, #f6f9ff 100%);
		border: 1px solid rgba(47, 103, 246, 0.12);
	}

	.qr-badge,
	.upload-card {
		display: inline-flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.9rem 1rem;
		background: rgba(255, 255, 255, 0.92);
		border-radius: 18px;
		border: 1px solid rgba(29, 41, 57, 0.08);
		box-shadow: 0 20px 40px rgba(29, 41, 57, 0.1);
		font-weight: 700;
	}

	.qr-badge {
		max-width: max-content;
	}

	.upload-card {
		position: absolute;
		top: 1.35rem;
		right: 1.35rem;
	}

	.upload-card strong {
		font-size: 1.8rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.photo-stack {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 3rem;
	}

	.photo-stack div {
		min-height: 122px;
		border-radius: 24px;
		background-size: cover;
		background-position: center;
		box-shadow: 0 16px 28px rgba(29, 41, 57, 0.12);
	}

	.photo-stack div:nth-child(1) {
		background:
			linear-gradient(135deg, rgba(47, 103, 246, 0.82), rgba(182, 208, 255, 0.4)),
			#dce9ff;
	}

	.photo-stack div:nth-child(2) {
		background:
			linear-gradient(135deg, rgba(15, 23, 42, 0.78), rgba(124, 146, 184, 0.26)),
			#dae4f6;
		transform: translateY(1rem);
	}

	.photo-stack div:nth-child(3) {
		background:
			linear-gradient(135deg, rgba(93, 124, 195, 0.76), rgba(217, 231, 255, 0.32)),
			#e6eefc;
	}

	.photo-stack div:nth-child(4) {
		background:
			linear-gradient(135deg, rgba(6, 182, 212, 0.62), rgba(217, 231, 255, 0.28)),
			#dff8ff;
		transform: translateY(1rem);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.stats-grid div {
		padding: 1rem 1.1rem;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid var(--line);
		border-radius: 18px;
	}

	.stats-grid span,
	.pricing-card p,
	.faq-item p,
	.site-footer p,
	.step-card p,
	.benefit-card p {
		color: var(--muted);
		line-height: 1.7;
	}

	.stats-grid strong {
		display: block;
		margin-top: 0.35rem;
		font-size: 1.45rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.steps-grid,
	.benefits-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.step-card,
	.benefit-card {
		padding: 1.6rem;
	}

	.step-index {
		display: inline-flex;
		margin-bottom: 1rem;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(47, 103, 246, 0.12);
		color: var(--primary-deep);
		font-size: 0.92rem;
		font-weight: 800;
	}

	.step-card h3,
	.benefit-card h3,
	.pricing-card h3 {
		margin: 0 0 0.7rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.4rem;
	}

	.benefits-section {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0));
	}

	.pricing-card {
		padding: 2rem;
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) auto;
		gap: 1.5rem 2rem;
		align-items: center;
	}

	.price-tag {
		min-width: 210px;
		padding: 1.25rem;
		border-radius: 24px;
		background: linear-gradient(135deg, #1d2939 0%, #2f67f6 100%);
		color: #fff;
		text-align: center;
	}

	.price-tag span {
		display: block;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 2.35rem;
		font-weight: 800;
	}

	.price-tag small {
		opacity: 0.8;
	}

	.pricing-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem 1rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.pricing-list li {
		padding-left: 1.2rem;
		position: relative;
		font-weight: 700;
	}

	.pricing-list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55rem;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--primary);
	}

	.faq-layout {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		gap: 2rem;
		align-items: start;
	}

	.faq-list {
		display: grid;
		gap: 1rem;
	}

	.faq-item {
		padding: 1.25rem 1.35rem;
	}

	.faq-item summary {
		cursor: pointer;
		list-style: none;
		font-weight: 800;
		font-size: 1.05rem;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item p {
		margin: 0.9rem 0 0;
	}

	.cta-card {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) auto;
		gap: 1.5rem 2rem;
		padding: 2rem;
		align-items: center;
		background:
			radial-gradient(circle at top left, rgba(217, 231, 255, 0.85), transparent 24%),
			linear-gradient(135deg, rgba(47, 103, 246, 0.12), rgba(93, 124, 195, 0.08)),
			#fff;
	}

	.cta-card h2 {
		margin: 1rem 0 0.75rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 4vw, 3.1rem);
		line-height: 1.05;
	}

	.cta-card p {
		margin: 0;
		color: var(--muted);
		font-size: 1.08rem;
		line-height: 1.7;
		max-width: 56ch;
	}

	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		justify-content: flex-end;
	}

	.site-footer {
		padding: 0 0 2.5rem;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(29, 41, 57, 0.1);
	}

	.footer-brand {
		display: inline-block;
		margin-bottom: 0.65rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 800;
		font-size: 1.1rem;
	}

	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		font-weight: 700;
		color: var(--muted);
	}

	@media (max-width: 960px) {
		.hero-grid,
		.faq-layout,
		.cta-card,
		.pricing-card {
			grid-template-columns: 1fr;
		}

		.steps-grid,
		.benefits-grid,
		.pricing-list {
			grid-template-columns: 1fr 1fr;
		}

		.cta-actions {
			justify-content: flex-start;
		}
	}

	@media (max-width: 720px) {
		.hero-copy h1 {
			max-width: none;
		}

		.steps-grid,
		.benefits-grid,
		.pricing-list,
		.stats-grid {
			grid-template-columns: 1fr;
		}

		.phone-frame {
			min-height: auto;
		}

		.upload-card {
			position: static;
			margin-top: 1rem;
		}

		.footer-content {
			flex-direction: column;
		}
	}
</style>

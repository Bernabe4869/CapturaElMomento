---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Recoge fotos de invitados para bodas y eventos con QR | Captura el Momento';
const pageDescription =
	'Recopila fotos de invitados en bodas y eventos con un album compartido y un QR. Tus invitados pueden subir fotos desde el movil, sin instalar app complicada.';

const steps = [
	{
		title: 'Crea tu album compartido',
		description:
			'Prepara el evento en pocos minutos, personaliza la portada y deja listo un espacio unico para recopilar recuerdos.',
	},
	{
		title: 'Comparte el QR con tus invitados',
		description:
			'Coloca el QR en mesas, invitaciones o pantallas para que cualquier persona pueda entrar desde el movil en segundos.',
	},
	{
		title: 'Recibe fotos durante todo el evento',
		description:
			'Cada invitado puede subir fotos desde el movil al instante y el album se completa con momentos reales de la celebracion.',
	},
];

const eventTypes = [
	{
		title: 'Bodas',
		description:
			'Ideal para recoger fotos de los invitados de una boda y sumar miradas espontaneas al album del gran dia.',
	},
	{
		title: 'Cumpleanos y fiestas privadas',
		description:
			'Convierte cualquier celebracion en un album compartido facil de usar para amigos, familia y anfitriones.',
	},
	{
		title: 'Comuniones, bautizos y eventos familiares',
		description:
			'Una forma simple de recopilar recuerdos sin perseguir fotos despues ni depender de varios chats.',
	},
	{
		title: 'Eventos de empresa y celebraciones de equipo',
		description:
			'Reune fotos de asistentes, equipo y organizacion en un solo sitio con acceso rapido mediante QR.',
	},
	{
		title: 'Baby showers y despedidas',
		description:
			'Perfecto para eventos donde cada invitado captura momentos distintos y quieres conservarlos todos.',
	},
	{
		title: 'Cualquier evento con invitados',
		description:
			'Si necesitas recopilar recuerdos en un solo lugar, el flujo funciona igual de bien en eventos pequenos o grandes.',
	},
];

const comparisonItems = [
	{
		title: 'Frente a WhatsApp',
		description:
			'Evitas fotos perdidas entre mensajes, compresion de archivos y la tarea de ir rescatando imagenes una por una.',
	},
	{
		title: 'Frente a carpetas dispersas',
		description:
			'No dependes de enlaces distintos, permisos confusos ni varias carpetas separadas para un mismo evento.',
	},
	{
		title: 'Frente a pedir fotos despues',
		description:
			'Recoges mas contenido porque los invitados comparten en el momento, cuando todavia tienen las fotos a mano.',
	},
];

const faqItems = [
	{
		question: 'Como puedo recoger fotos de los invitados de una boda con un QR?',
		answer:
			'Creas el evento, generas un QR y lo compartes en la boda. Los invitados lo escanean y pueden subir fotos desde el movil al album compartido en pocos pasos.',
	},
	{
		question: 'Los invitados tienen que instalar una app para subir fotos?',
		answer:
			'No. Captura el Momento esta pensado para que cualquier invitado pueda acceder desde el navegador del movil, sin instalar app complicada ni seguir instrucciones largas.',
	},
	{
		question: 'Sirve solo para bodas o tambien para otros eventos?',
		answer:
			'Funciona muy bien en bodas, pero tambien en cumpleanos, comuniones, bautizos, baby showers, fiestas privadas y eventos de empresa donde quieras recopilar fotos de invitados.',
	},
	{
		question: 'Que ventajas tiene frente a pedir fotos por WhatsApp?',
		answer:
			'Con un album compartido por QR tienes todas las fotos del evento en un mismo lugar, sin chats caoticos, archivos mezclados ni mensajes que se pierden con el tiempo.',
	},
	{
		question: 'Por que es mejor pedir las fotos durante el evento y no dias despues?',
		answer:
			'Durante el evento los invitados ya tienen el movil en la mano y recuerdan compartir. Si esperas a despues, muchas fotos no llegan, se olvidan o quedan repartidas en varias conversaciones y carpetas.',
	},
	{
		question: 'Que tipo de recuerdos puedo recopilar en el album?',
		answer:
			'Puedes reunir fotos de invitados, momentos espontaneos, detalles de decoracion, pista de baile, mesas, ceremonia y cualquier imagen que ayude a reconstruir el evento desde muchas perspectivas.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const softwareSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Captura el Momento',
	applicationCategory: 'PhotoApplication',
	operatingSystem: 'Web',
	url: 'https://capturaelmomento.com/',
	description: pageDescription,
	inLanguage: 'es',
	featureList: [
		'Album compartido para bodas y eventos',
		'Acceso mediante QR',
		'Subir fotos desde el movil',
		'Sin instalar app complicada',
		'Recopilar fotos de invitados en un solo lugar',
	],
	audience: {
		'@type': 'Audience',
		audienceType: 'Parejas, anfitriones y personas que organizan eventos',
	},
	producer: {
		'@type': 'Organization',
		name: 'Captura el Momento',
		url: 'https://capturaelmomento.com/',
	},
};

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'Captura el Momento',
	url: 'https://capturaelmomento.com/',
	logo: 'https://capturaelmomento.com/favicon.png',
	description:
		'Software para recopilar fotos de invitados en bodas y eventos mediante un album compartido con QR.',
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Captura el Momento',
	url: 'https://capturaelmomento.com/',
	inLanguage: 'es',
	description:
		'Sitio web para crear albumes compartidos y recoger fotos de invitados en bodas y eventos con un QR.',
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="/"
	structuredData={[softwareSchema, faqSchema, organizationSchema, websiteSchema]}
>
	<main>
		<section class="hero section" id="hero-top">
			<div class="container hero-grid">
				<div class="hero-copy">
					<span class="eyebrow">Album compartido con QR para bodas y eventos</span>
					<h1>Recoge las fotos de tus invitados con un QR y guardalas en un solo album compartido.</h1>
					<p class="hero-lead">
						Captura el Momento te ayuda a recopilar recuerdos de una boda o cualquier evento sin
						chats caoticos, sin carpetas dispersas y sin instalar app complicada.
					</p>
					<p class="hero-support">
						Tus invitados pueden subir fotos desde el movil en segundos, mientras tu mantienes todo
						ordenado, accesible y listo para revivir despues.
					</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href="https://app.capturaelmomento.com">Crear mi evento</a>
						<a class="btn btn-secondary" href="#como-funciona">Ver como funciona</a>
					</div>
					<ul class="hero-proof" aria-label="Ventajas principales">
						<li>Fotos de invitados centralizadas</li>
						<li>Subida rapida desde movil con QR</li>
						<li>Experiencia simple y elegante</li>
					</ul>
				</div>
				<div class="hero-panel card">
					<div class="hero-panel-top">
						<p class="panel-label">Vista del evento</p>
						<strong>Album activo y listo para compartir</strong>
					</div>
					<div class="phone-frame">
						<div class="qr-badge">QR + enlace listos para tus invitados</div>
						<div class="upload-card">
							<span>Fotos de invitados</span>
							<strong>11</strong>
						</div>
						<div class="photo-stack" aria-hidden="true">
							<div></div>
							<div></div>
							<div></div>
							<div></div>
						</div>
					</div>
					<div class="stats-grid">
						<div>
							<span>Album compartido</span>
							<strong>Activo</strong>
						</div>
						<div>
							<span>Acceso para invitados</span>
							<strong>Por QR</strong>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="section" id="como-funciona">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Como funciona</span>
					<h2>Como recopilar fotos de invitados sin complicar a nadie.</h2>
					<p>
						El proceso esta pensado para convertir una accion que suele ser caotica en una
						experiencia clara: crear, compartir y recibir fotos del evento en un mismo lugar.
					</p>
				</div>

				<div class="grid steps-grid">
					{
						steps.map((step, index) => (
							<article class="card step-card">
								<div class="step-index">0{index + 1}</div>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section seo-wedding-section" id="bodas">
			<div class="container wedding-layout">
				<div class="section-heading">
					<span class="eyebrow">Especial bodas</span>
					<h2>Recoger fotos de los invitados de una boda sin perseguir a nadie despues.</h2>
					<p>
						En muchas bodas pasa lo mismo: los novios saben que hay fotos preciosas en los moviles de
						los invitados, pero pedirlas una a una por WhatsApp resulta lento, incomodo y poco
						efectivo.
					</p>
				</div>
				<div class="card wedding-card">
					<p>
						Con Captura el Momento, compartes un QR durante la boda y cada invitado puede subir fotos
						desde el movil al momento. Asi consigues un album compartido mas completo, con momentos
						espontaneos que normalmente no llegan al final.
					</p>
					<p>
						La ventaja no es solo tecnica. Tambien mejora la experiencia: menos mensajes despues del
						evento, menos archivos desperdigados y una forma mas natural de recopilar recuerdos del dia.
					</p>
				</div>
			</div>
		</section>

		<section class="section events-section" id="eventos">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Para que eventos sirve</span>
					<h2>Una solucion pensada para bodas, celebraciones y eventos donde cada invitado aporta recuerdos.</h2>
					<p>
						Si hay personas haciendo fotos con su movil, hay una oportunidad clara de reunir esos
						momentos en un album compartido bien organizado.
					</p>
				</div>

				<div class="grid benefits-grid">
					{
						eventTypes.map((eventType) => (
							<article class="card benefit-card">
								<h3>{eventType.title}</h3>
								<p>{eventType.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section compare-section" id="ventajas">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Ventajas frente a pedir fotos por WhatsApp</span>
					<h2>Mas orden, mas participacion y menos friccion antes, durante y despues del evento.</h2>
					<p>
						Cuando facilitas el acceso con un QR y un flujo simple, recopilar recuerdos deja de ser
						una tarea pendiente y pasa a formar parte natural del evento.
					</p>
				</div>

				<div class="grid comparison-grid">
					{
						comparisonItems.map((item) => (
							<article class="card comparison-card">
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section promo-section" id="promo">
			<div class="container">
				<div class="promo-banner card">
					<div>
						<p class="pricing-kicker">Promocion de lanzamiento</p>
						<h2>Pruebalo en tu proximo evento con acceso promocional.</h2>
						<p>
							La propuesta principal de la pagina ya es evergreen. Si quieres aprovechar la etapa de
							lanzamiento, puedes empezar ahora y validar la experiencia en un evento real.
						</p>
					</div>
					<a class="btn btn-primary" href="https://app.capturaelmomento.com">Quiero probarla</a>
				</div>
			</div>
		</section>

		<section class="section faq-section" id="faq">
			<div class="container faq-layout">
				<div class="section-heading">
					<span class="eyebrow">Preguntas frecuentes</span>
					<h2>Respuestas claras sobre albumes compartidos con QR para bodas y eventos.</h2>
					<p>
						Esta FAQ ayuda a resolver dudas reales de quienes buscan una forma simple de recopilar
						fotos de invitados y, ademas, refuerza la comprension semantica de la pagina.
					</p>
				</div>
				<div class="faq-list">
					{
						faqItems.map((item) => (
							<details class="card faq-item">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="section final-cta" id="cta-final">
			<div class="container">
				<div class="card cta-card">
					<div>
						<span class="eyebrow">Listo para recopilar recuerdos mejor</span>
						<h2>Haz que las fotos de tus invitados terminen donde deben: en tu album compartido.</h2>
						<p>
							Crea tu evento, comparte el QR y deja que cada persona suba fotos desde el movil de
							forma natural, sin friccion y sin perder momentos valiosos.
						</p>
					</div>
					<div class="cta-actions">
						<a class="btn btn-primary" href="https://app.capturaelmomento.com">Entrar en la app</a>
						<a class="btn btn-secondary" href="#hero-top">Volver arriba</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container footer-content">
			<div>
				<a class="footer-brand" href="/">Captura el Momento</a>
				<p>Recopila fotos de invitados en bodas y eventos con un QR y un album compartido.</p>
			</div>
			<nav aria-label="Navegacion secundaria" class="footer-nav">
				<a href="#como-funciona">Como funciona</a>
				<a href="#bodas">Bodas</a>
				<a href="#eventos">Eventos</a>
				<a href="#ventajas">Ventajas</a>
				<a href="#faq">FAQ</a>
			</nav>
		</div>
	</footer>
</Layout>

<style>
	.hero {
		padding-top: 2rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: 2rem;
		align-items: center;
	}

	.hero-copy h1 {
		margin: 1rem 0 1rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(3rem, 6vw, 5.2rem);
		line-height: 0.96;
		letter-spacing: -0.04em;
		max-width: 11ch;
	}

	.hero-copy p {
		max-width: 60ch;
		margin: 0;
		font-size: 1.06rem;
		line-height: 1.8;
		color: var(--muted);
	}

	.hero-lead {
		font-size: 1.14rem;
	}

	.hero-support {
		margin-top: 0.9rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin: 2rem 0 1.5rem;
	}

	.hero-proof {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.hero-proof li {
		padding: 0.7rem 0.95rem;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid var(--line);
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 700;
	}

	.hero-panel {
		padding: 1.5rem;
		position: relative;
		overflow: hidden;
	}

	.hero-panel::before {
		content: '';
		position: absolute;
		inset: auto -10% -18% auto;
		width: 240px;
		height: 240px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(217, 231, 255, 0.95), transparent 68%);
	}

	.hero-panel-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.panel-label,
	.pricing-kicker {
		margin: 0 0 0.3rem;
		font-size: 0.92rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--secondary);
	}

	.phone-frame {
		position: relative;
		min-height: 420px;
		padding: 1.35rem;
		border-radius: 28px;
		background:
			linear-gradient(180deg, rgba(47, 103, 246, 0.1), rgba(255, 255, 255, 0.76)),
			linear-gradient(135deg, #fff 0%, #f6f9ff 100%);
		border: 1px solid rgba(47, 103, 246, 0.12);
	}

	.qr-badge,
	.upload-card {
		display: inline-flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.9rem 1rem;
		background: rgba(255, 255, 255, 0.92);
		border-radius: 18px;
		border: 1px solid rgba(29, 41, 57, 0.08);
		box-shadow: 0 20px 40px rgba(29, 41, 57, 0.1);
		font-weight: 700;
	}

	.qr-badge {
		max-width: max-content;
	}

	.upload-card {
		position: absolute;
		top: 1.35rem;
		right: 1.35rem;
	}

	.upload-card strong {
		font-size: 1.8rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.photo-stack {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 3rem;
	}

	.photo-stack div {
		min-height: 122px;
		border-radius: 24px;
		background-size: cover;
		background-position: center;
		box-shadow: 0 16px 28px rgba(29, 41, 57, 0.12);
	}

	.photo-stack div:nth-child(1) {
		background:
			linear-gradient(135deg, rgba(47, 103, 246, 0.82), rgba(182, 208, 255, 0.4)),
			#dce9ff;
	}

	.photo-stack div:nth-child(2) {
		background:
			linear-gradient(135deg, rgba(15, 23, 42, 0.78), rgba(124, 146, 184, 0.26)),
			#dae4f6;
		transform: translateY(1rem);
	}

	.photo-stack div:nth-child(3) {
		background:
			linear-gradient(135deg, rgba(93, 124, 195, 0.76), rgba(217, 231, 255, 0.32)),
			#e6eefc;
	}

	.photo-stack div:nth-child(4) {
		background:
			linear-gradient(135deg, rgba(6, 182, 212, 0.62), rgba(217, 231, 255, 0.28)),
			#dff8ff;
		transform: translateY(1rem);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.stats-grid div {
		padding: 1rem 1.1rem;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid var(--line);
		border-radius: 18px;
	}

	.stats-grid span,
	.promo-banner p,
	.faq-item p,
	.site-footer p,
	.step-card p,
	.benefit-card p,
	.comparison-card p,
	.wedding-card p {
		color: var(--muted);
		line-height: 1.7;
	}

	.stats-grid strong {
		display: block;
		margin-top: 0.35rem;
		font-size: 1.45rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.steps-grid,
	.benefits-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.comparison-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.step-card,
	.benefit-card,
	.comparison-card {
		padding: 1.6rem;
	}

	.step-index {
		display: inline-flex;
		margin-bottom: 1rem;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(47, 103, 246, 0.12);
		color: var(--primary-deep);
		font-size: 0.92rem;
		font-weight: 800;
	}

	.step-card h3,
	.benefit-card h3,
	.comparison-card h3,
	.promo-banner h2 {
		margin: 0 0 0.7rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.4rem;
	}

	.events-section,
	.compare-section {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0));
	}

	.wedding-layout {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		gap: 2rem;
		align-items: center;
	}

	.wedding-card,
	.promo-banner {
		padding: 2rem;
	}

	.promo-banner {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) auto;
		gap: 1.5rem 2rem;
		align-items: center;
	}

	.faq-layout {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		gap: 2rem;
		align-items: start;
	}

	.faq-list {
		display: grid;
		gap: 1rem;
	}

	.faq-item {
		padding: 1.25rem 1.35rem;
	}

	.faq-item summary {
		cursor: pointer;
		list-style: none;
		font-weight: 800;
		font-size: 1.05rem;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item p {
		margin: 0.9rem 0 0;
	}

	.cta-card {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) auto;
		gap: 1.5rem 2rem;
		padding: 2rem;
		align-items: center;
		background:

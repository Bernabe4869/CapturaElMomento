---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'App para recopilar fotos de boda y eventos con QR | Captura el Momento';
const pageDescription =
	'Recopila fotos de invitados en bodas y eventos con un álbum compartido y un QR. Tus invitados pueden subir fotos desde el móvil, sin instalar una app complicada.';

const steps = [
	{
		title: 'Crea tu evento y deja listo el álbum',
		description:
			'Configura el nombre, prepara la portada y crea un álbum digital pensado para recopilar fotos en un solo lugar.',
	},
	{
		title: 'Comparte el QR o el enlace',
		description:
			'Colócalo en mesas, invitaciones o pantallas para que cualquier invitado pueda acceder desde el móvil en segundos.',
	},
	{
		title: 'Recibe fotos durante el evento',
		description:
			'Los invitados suben fotos desde el móvil mientras todo ocurre y el álbum compartido se va llenando con recuerdos reales del evento.',
	},
];

const benefits = [
	{
		title: 'Más fotos de invitados, con menos esfuerzo',
		description:
			'Recibes momentos espontáneos que normalmente se pierden cuando las fotos se quedan en móviles ajenos.',
	},
	{
		title: 'Sin instalar una app complicada',
		description:
			'El acceso está pensado para ser simple, rápido y natural incluso para invitados poco tecnológicos.',
	},
	{
		title: 'Todo ordenado en un solo álbum compartido',
		description:
			'Evitas fotos dispersas, enlaces distintos y conversaciones interminables para reunir recuerdos después.',
	},
];

const privateEventTypes = [
	{
		title: 'Cumpleaños',
		description:
			'Una forma sencilla de reunir fotos de amigos y familia sin depender de varios chats ni pedirlas días después.',
	},
	{
		title: 'Fiestas privadas',
		description:
			'Ideal para celebraciones donde muchas personas hacen fotos y quieres conservarlas en un único álbum digital.',
	},
	{
		title: 'Comuniones y celebraciones familiares',
		description:
			'Te ayuda a recopilar fotos de invitados y momentos importantes sin perder tiempo organizando carpetas más tarde.',
	},
];

const comparisonItems = [
	{
		title: 'Frente a WhatsApp',
		description:
			'Evitas la compresión de imágenes, los mensajes perdidos y la tarea de rescatar fotos una por una entre conversaciones.',
	},
	{
		title: 'Frente a carpetas compartidas dispersas',
		description:
			'No dependes de varios enlaces, permisos confusos o carpetas separadas para un mismo evento.',
	},
	{
		title: 'Frente a pedir fotos después',
		description:
			'Recoges más contenido porque el invitado comparte cuando ya tiene el móvil en la mano y el momento todavía está presente.',
	},
];

const faqItems = [
	{
		question: '¿Cómo recopilar las fotos de los invitados en una boda?',
		answer:
			'La forma más sencilla es compartir un QR durante la boda para que cada invitado pueda entrar al álbum y subir sus fotos desde el móvil en el momento.',
	},
	{
		question: '¿Hace falta instalar una app para subir fotos?',
		answer:
			'No. Captura el Momento está pensado para que los invitados accedan desde el navegador del móvil, sin instalar una app complicada ni seguir pasos largos.',
	},
	{
		question: '¿Cómo compartir un álbum de fotos por QR en un evento?',
		answer:
			'Creas el evento, generas el QR y lo compartes en mesas, carteles, invitaciones o pantallas. Los invitados lo escanean y pueden subir fotos al álbum compartido.',
	},
	{
		question: '¿Qué alternativa hay a pedir fotos por WhatsApp?',
		answer:
			'Un álbum compartido con QR es una alternativa mucho más ordenada. Reúne todas las fotos del evento en un solo lugar y evita chats caóticos y archivos mezclados.',
	},
	{
		question: '¿Sirve para cumpleaños, comuniones o fiestas?',
		answer:
			'Sí. Aunque tiene un gran encaje en bodas, también funciona muy bien para cumpleaños, comuniones, fiestas privadas y otras celebraciones con invitados.',
	},
	{
		question: '¿Puedo reunir todas las fotos en un solo álbum digital?',
		answer:
			'Sí. La idea es precisamente recopilar recuerdos del evento en un único álbum digital para que no queden repartidos entre móviles, chats y carpetas.',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};

const softwareSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Captura el Momento',
	applicationCategory: 'PhotoApplication',
	operatingSystem: 'Web',
	url: 'https://capturaelmomento.com/',
	description: pageDescription,
	inLanguage: 'es-ES',
	featureList: [
		'Álbum compartido para bodas y eventos',
		'Acceso mediante QR o enlace',
		'Subida de fotos desde el móvil',
		'Sin instalar una app complicada',
		'Recopilar fotos de invitados en un solo lugar',
	],
	audience: {
		'@type': 'Audience',
		audienceType: 'Parejas, anfitriones y personas que organizan eventos',
	},
	producer: {
		'@type': 'Organization',
		name: 'Captura el Momento',
		url: 'https://capturaelmomento.com/',
	},
};

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'Captura el Momento',
	url: 'https://capturaelmomento.com/',
	logo: 'https://capturaelmomento.com/favicon.png',
	description:
		'Software para recopilar fotos de invitados en bodas y eventos mediante un álbum compartido con QR.',
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Captura el Momento',
	url: 'https://capturaelmomento.com/',
	inLanguage: 'es-ES',
	description:
		'Sitio web para crear álbumes compartidos y recoger fotos de invitados en bodas y eventos con un QR.',
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="/"
	structuredData={[softwareSchema, faqSchema, organizationSchema, websiteSchema]}
>
	<header class="hero section" id="hero-top">
		<div class="container hero-grid">
			<div class="hero-copy">
				<span class="eyebrow">Álbum compartido con QR para bodas y eventos</span>
				<h1>La app para recopilar fotos de invitados en bodas y eventos con un QR.</h1>
				<p class="hero-lead">
					Captura el Momento te ayuda a reunir las fotos de una boda o cualquier evento en un
					solo álbum compartido, sin WhatsApp, sin carpetas dispersas y sin instalar una app
					complicada.
				</p>
				<p class="hero-support">
					Crea el evento, comparte el QR o el enlace y deja que tus invitados suban fotos desde
					el móvil mientras tú mantienes todos los recuerdos del evento ordenados y accesibles.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="https://app.capturaelmomento.com">Crear mi evento</a>
					<a class="btn btn-secondary" href="#como-funciona">Ver cómo funciona</a>
				</div>
				<ul class="hero-proof" aria-label="Ventajas principales">
					<li>Fotos de invitados en un solo lugar</li>
					<li>Subida rápida desde el móvil con QR</li>
					<li>Sin instalar una app complicada</li>
				</ul>
			</div>
			<div class="hero-panel card" aria-label="Vista previa del álbum del evento">
				<div class="hero-panel-top">
					<p class="panel-label">Vista del evento</p>
					<strong>Álbum activo y listo para compartir</strong>
				</div>
				<div class="phone-frame">
					<div class="phone-top">
						<div class="qr-badge">QR + enlace listos para tus invitados</div>
						<div class="upload-card">
							<span>Fotos de invitados</span>
							<strong>11</strong>
						</div>
					</div>
					<div class="photo-stack" aria-hidden="true">
						<div></div>
						<div></div>
						<div></div>
						<div></div>
					</div>
				</div>
				<div class="stats-grid">
					<div>
						<span>Álbum compartido</span>
						<strong>Activo</strong>
					</div>
					<div>
						<span>Acceso para invitados</span>
						<strong>Por QR</strong>
					</div>
				</div>
			</div>
		</div>
	</header>

	<main>
		<section class="section" id="como-funciona" aria-labelledby="como-funciona-title">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Cómo funciona</span>
					<h2 id="como-funciona-title">Cómo recopilar fotos de invitados sin complicar a nadie.</h2>
					<p>
						El proceso está pensado para convertir una tarea que suele ser caótica en algo claro:
						crear, compartir y recibir fotos del evento en un mismo sitio.
					</p>
				</div>

				<div class="grid steps-grid">
					{
						steps.map((step, index) => (
							<article class="card step-card">
								<div class="step-index">0{index + 1}</div>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section benefits-section" id="beneficios" aria-labelledby="beneficios-title">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Beneficios</span>
					<h2 id="beneficios-title">Una forma más elegante de recoger fotos del evento.</h2>
					<p>
						La propuesta mejora tanto la experiencia de quien organiza como la de quien comparte:
						menos fricción, más participación y mejores recuerdos reunidos en el mismo lugar.
					</p>
				</div>

				<div class="grid benefits-grid">
					{
						benefits.map((benefit) => (
							<article class="card benefit-card">
								<h3>{benefit.title}</h3>
								<p>{benefit.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section seo-wedding-section" id="bodas" aria-labelledby="bodas-title">
			<div class="container wedding-layout">
				<div class="section-heading">
					<span class="eyebrow">Especial bodas</span>
					<h2 id="bodas-title">Recoger fotos de los invitados de una boda sin perseguir a nadie después.</h2>
					<p>
						En muchas bodas pasa lo mismo: los novios saben que hay fotos preciosas en los móviles
						de los invitados, pero pedirlas una a una por WhatsApp resulta lento, incómodo y poco
						efectivo.
					</p>
				</div>
				<div class="card wedding-card">
					<p>
						Con Captura el Momento, compartes un QR durante la boda y cada invitado puede subir
						fotos desde el móvil al momento. Así consigues un álbum compartido más completo, con
						miradas espontáneas que normalmente no llegan al final.
					</p>
					<p>
						La ventaja no es solo técnica. También mejora la experiencia posterior: menos mensajes,
						menos archivos desperdigados y una forma más natural de recopilar recuerdos del gran día.
					</p>
				</div>
			</div>
		</section>

		<section class="section events-section" id="celebraciones" aria-labelledby="celebraciones-title">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Cumpleaños, fiestas y comuniones</span>
					<h2 id="celebraciones-title">También funciona muy bien en celebraciones privadas y eventos familiares.</h2>
					<p>
						Si varias personas están haciendo fotos con el móvil, tiene sentido reunir esos
						recuerdos del evento en un álbum digital compartido y fácil de usar.
					</p>
				</div>

				<div class="grid benefits-grid">
					{
						privateEventTypes.map((eventType) => (
							<article class="card benefit-card">
								<h3>{eventType.title}</h3>
								<p>{eventType.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section compare-section" id="comparativa" aria-labelledby="comparativa-title">
			<div class="container">
				<div class="section-heading">
					<span class="eyebrow">Ventajas frente a WhatsApp y otras alternativas</span>
					<h2 id="comparativa-title">Más orden, más participación y menos fricción antes, durante y después del evento.</h2>
					<p>
						Cuando facilitas el acceso con un QR y un flujo claro, recopilar fotos deja de ser una
						tarea pendiente y pasa a formar parte natural del propio evento.
					</p>
				</div>

				<div class="grid comparison-grid">
					{
						comparisonItems.map((item) => (
							<article class="card comparison-card">
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section promo-section" id="promo" aria-labelledby="promo-title">
			<div class="container">
				<div class="promo-banner card">
					<div>
						<p class="pricing-kicker">Promoción de lanzamiento</p>
						<h2 id="promo-title">Prueba la experiencia en tu próximo evento.</h2>
						<p>
							La propuesta principal de la página es evergreen. Si quieres aprovechar una oferta o
							promoción puntual, este es el lugar adecuado para comunicarla sin convertirla en el eje
							del contenido indexable.
						</p>
					</div>
					<a class="btn btn-primary" href="https://app.capturaelmomento.com">Quiero probarla</a>
				</div>
			</div>
		</section>

		<section class="section faq-section" id="faq" aria-labelledby="faq-title">
			<div class="container faq-layout">
				<div class="section-heading">
					<span class="eyebrow">Preguntas frecuentes</span>
					<h2 id="faq-title">Respuestas claras sobre fotos de invitados, QR y álbumes compartidos.</h2>
					<p>
						Esta FAQ resuelve dudas reales de quienes buscan una alternativa a pedir fotos por
						WhatsApp y refuerza la semántica SEO de la landing.
					</p>
				</div>
				<div class="faq-list">
					{
						faqItems.map((item) => (
							<details class="card faq-item">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="section final-cta" id="cta-final" aria-labelledby="cta-final-title">
			<div class="container">
				<div class="card cta-card">
					<div>
						<span class="eyebrow">Listo para recopilar recuerdos mejor</span>
						<h2 id="cta-final-title">Haz que las fotos de tus invitados terminen donde deben: en tu álbum compartido.</h2>
						<p>
							Crea tu evento, comparte el QR y deja que cada persona suba fotos desde el móvil de
							forma natural, sin fricción y sin perder momentos valiosos por el camino.
						</p>
					</div>
					<div class="cta-actions">
						<a class="btn btn-primary" href="https://app.capturaelmomento.com">Crear mi álbum</a>
						<a class="btn btn-secondary" href="#hero-top">Volver arriba</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container footer-content">
			<div>
				<a class="footer-brand" href="/">Captura el Momento</a>
				<p>Recopila fotos de invitados en bodas y eventos con un QR y un álbum compartido.</p>
			</div>
			<nav aria-label="Navegación secundaria" class="footer-nav">
				<a href="#como-funciona">Cómo funciona</a>
				<a href="#beneficios">Beneficios</a>
				<a href="#bodas">Bodas</a>
				<a href="#celebraciones">Celebraciones</a>
				<a href="#comparativa">Comparativa</a>
				<a href="#faq">FAQ</a>
			</nav>
		</div>
	</footer>
</Layout>

<style>
	.hero {
		padding-top: 2rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: 2rem;
		align-items: center;
	}

	.hero-copy h1 {
		margin: 1rem 0 1rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(3rem, 6vw, 5.2rem);
		line-height: 0.96;
		letter-spacing: -0.04em;
		max-width: 12ch;
	}

	.hero-copy p {
		max-width: 60ch;
		margin: 0;
		font-size: 1.06rem;
		line-height: 1.8;
		color: var(--muted);
	}

	.hero-lead {
		font-size: 1.14rem;
	}

	.hero-support {
		margin-top: 0.9rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin: 2rem 0 1.5rem;
	}

	.hero-proof {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.hero-proof li {
		padding: 0.7rem 0.95rem;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid var(--line);
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 700;
	}

	.hero-panel {
		padding: 1.5rem;
		position: relative;
		overflow: hidden;
	}

	.hero-panel::before {
		content: '';
		position: absolute;
		inset: auto -10% -18% auto;
		width: 240px;
		height: 240px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(217, 231, 255, 0.95), transparent 68%);
	}

	.hero-panel-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.panel-label,
	.pricing-kicker {
		margin: 0 0 0.3rem;
		font-size: 0.92rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--secondary);
	}

	.phone-frame {
		position: relative;
		min-height: 420px;
		padding: 1.35rem;
		border-radius: 28px;
		background:
			linear-gradient(180deg, rgba(47, 103, 246, 0.1), rgba(255, 255, 255, 0.76)),
			linear-gradient(135deg, #fff 0%, #f6f9ff 100%);
		border: 1px solid rgba(47, 103, 246, 0.12);
	}

	.qr-badge,
	.upload-card {
		display: inline-flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.9rem 1rem;
		background: rgba(255, 255, 255, 0.92);
		border-radius: 18px;
		border: 1px solid rgba(29, 41, 57, 0.08);
		box-shadow: 0 20px 40px rgba(29, 41, 57, 0.1);
		font-weight: 700;
	}

	.qr-badge {
		max-width: 100%;
	}

	.phone-top {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.9rem;
		align-items: start;
	}

	.upload-card strong {
		font-size: 1.8rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.photo-stack {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.75rem;
	}

	.photo-stack div {
		min-height: 122px;
		border-radius: 24px;
		background-size: cover;
		background-position: center;
		box-shadow: 0 16px 28px rgba(29, 41, 57, 0.12);
	}

	.photo-stack div:nth-child(1) {
		background:
			linear-gradient(135deg, rgba(47, 103, 246, 0.82), rgba(182, 208, 255, 0.4)),
			#dce9ff;
	}

	.photo-stack div:nth-child(2) {
		background:
			linear-gradient(135deg, rgba(15, 23, 42, 0.78), rgba(124, 146, 184, 0.26)),
			#dae4f6;
		transform: translateY(1rem);
	}

	.photo-stack div:nth-child(3) {
		background:
			linear-gradient(135deg, rgba(93, 124, 195, 0.76), rgba(217, 231, 255, 0.32)),
			#e6eefc;
	}

	.photo-stack div:nth-child(4) {
		background:
			linear-gradient(135deg, rgba(6, 182, 212, 0.62), rgba(217, 231, 255, 0.28)),
			#dff8ff;
		transform: translateY(1rem);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.stats-grid div {
		padding: 1rem 1.1rem;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid var(--line);
		border-radius: 18px;
	}

	.stats-grid span,
	.promo-banner p,
	.faq-item p,
	.site-footer p,
	.step-card p,
	.benefit-card p,
	.comparison-card p,
	.wedding-card p {
		color: var(--muted);
		line-height: 1.7;
	}

	.stats-grid strong {
		display: block;
		margin-top: 0.35rem;
		font-size: 1.45rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.steps-grid,
	.benefits-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.comparison-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.step-card,
	.benefit-card,
	.comparison-card {
		padding: 1.6rem;
	}

	.step-index {
		display: inline-flex;
		margin-bottom: 1rem;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(47, 103, 246, 0.12);
		color: var(--primary-deep);
		font-size: 0.92rem;
		font-weight: 800;
	}

	.step-card h3,
	.benefit-card h3,
	.comparison-card h3,
	.promo-banner h2 {

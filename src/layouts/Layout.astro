---
import SEO from '../components/SEO.astro';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = 'Captura el Momento | Comparte fotos de eventos con un QR',
	description = 'Crea un album digital para bodas, fiestas y cumpleaños. Comparte un QR y deja que todos suban sus fotos en segundos. Gratis hasta julio.',
	canonical,
	ogImage = '/og-captura-el-momento.png',
	noindex = false,
	structuredData,
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;700;800&display=swap"
			rel="stylesheet"
		/>
		<SEO
			title={title}
			description={description}
			canonical={canonical}
			ogImage={ogImage}
			noindex={noindex}
			structuredData={structuredData}
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #f4f8ff;
		--bg-soft: #fbfdff;
		--surface: rgba(255, 255, 255, 0.8);
		--surface-strong: #ffffff;
		--text: #1d2939;
		--muted: #526077;
		--line: rgba(29, 41, 57, 0.12);
		--primary: #2f67f6;
		--primary-deep: #1e4fd0;
		--secondary: #5d7cc3;
		--accent: #d9e7ff;
		--shadow: 0 24px 60px rgba(29, 41, 57, 0.12);
		--radius-xl: 32px;
		--radius-lg: 24px;
		--radius-md: 18px;
		--container: 1160px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		font-family: 'Manrope', sans-serif;
		color: var(--text);
		background:
			radial-gradient(circle at top left, rgba(217, 231, 255, 0.9), transparent 32%),
			radial-gradient(circle at top right, rgba(47, 103, 246, 0.1), transparent 28%),
			linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
	}

	img {
		max-width: 100%;
		display: block;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	.container {
		width: min(calc(100% - 2rem), var(--container));
		margin: 0 auto;
	}

	.section {
		padding: 5rem 0;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.68);
		border: 1px solid rgba(47, 103, 246, 0.18);
		color: var(--primary);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.section-heading {
		max-width: 720px;
		margin-bottom: 2.5rem;
	}

	.section-heading h2 {
		margin: 0.85rem 0 0.75rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 3.8vw, 3.25rem);
		line-height: 1.05;
	}

	.section-heading p {
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.7;
		color: var(--muted);
	}

	.grid {
		display: grid;
		gap: 1.5rem;
	}

	.card {
		background: var(--surface);
		backdrop-filter: blur(18px);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.95rem 1.4rem;
		border-radius: 999px;
		border: 1px solid transparent;
		font-weight: 800;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--primary) 0%, #4b80ff 100%);
		color: #fff;
		box-shadow: 0 16px 30px rgba(47, 103, 246, 0.28);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.72);
		border-color: var(--line);
		color: var(--text);
	}

	@media (max-width: 720px) {
		.section {
			padding: 4rem 0;
		}
	}
</style>
